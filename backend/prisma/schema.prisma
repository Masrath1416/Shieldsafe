// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model
model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  password          String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  // Relations
  emergencyContacts EmergencyContact[]
  sosAlerts         SOSAlert[]
  locations         Location[]
  journeys          Journey[]
  safetyTimers      SafetyTimer[]
}

// Emergency Contacts Model
model EmergencyContact {
  id           String   @id @default(uuid())
  userId       String
  contactName  String
  contactPhone String
  relationship String
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// SOS Alerts Model
model SOSAlert {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  alertTime DateTime @default(now())
  status    String   @default("Active") // Active, Resolved, Cancelled

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Location Tracking Model
model Location {
  id        String   @id @default(uuid())
  userId    String
  latitude  Float
  longitude Float
  createdAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Journey Mode Model
model Journey {
  id          String    @id @default(uuid())
  userId      String
  destination String
  eta         DateTime
  status      String    @default("In-Progress") // In-Progress, Completed, Cancelled
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Safety Timer Model
model SafetyTimer {
  id        String   @id @default(uuid())
  userId    String
  duration  Int      // in minutes
  status    String   @default("Running") // Running, Safe, Expired
  startedAt DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
